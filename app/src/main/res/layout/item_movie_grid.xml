<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_app"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgPosterGrid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedImageView"
            app:layout_constraintDimensionRatio="2:3"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@android:drawable/ic_menu_gallery" />

        <!-- Overlay para películas vistas -->
        <View
            android:id="@+id/viewWatchedOverlayGrid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="#80000000"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/imgPosterGrid"
            app:layout_constraintTop_toTopOf="@id/imgPosterGrid" />

        <ImageView
            android:id="@+id/imgWatchedBadgeGrid"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_view"
            android:visibility="gone"
            app:tint="@color/accent"
            app:layout_constraintBottom_toBottomOf="@id/imgPosterGrid"
            app:layout_constraintEnd_toEndOf="@id/imgPosterGrid"
            app:layout_constraintStart_toStartOf="@id/imgPosterGrid"
            app:layout_constraintTop_toTopOf="@id/imgPosterGrid" />

        <ImageView
            android:id="@+id/imgFavoriteBadgeGrid"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_margin="6dp"
            android:src="@drawable/ic_heart_filled"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="@drawable/gradient_overlay"
            app:layout_constraintBottom_toBottomOf="@id/imgPosterGrid" />

        <TextView
            android:id="@+id/textRatingGrid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            android:textColor="@color/accent"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/imgPosterGrid"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="★ 8.5" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
