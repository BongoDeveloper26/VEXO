<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <!-- Header Premium Limpio -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="32dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textTitleHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Biblioteca"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.04"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateList"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@color/surface_app"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="@color/primary"
            app:iconSize="28dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:shapeAppearanceOverlay="@style/RoundedImageView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutLists"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:tabIndicatorColor="@color/primary"
        app:tabSelectedTextColor="@color/text_primary"
        app:tabTextColor="@color/text_secondary"
        app:tabIndicatorHeight="3dp"
        app:tabIndicatorFullWidth="false"
        app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Subtitle2"
        app:tabRippleColor="@null"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerList">
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MIS LISTAS" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OTRAS LISTAS" />
    </com.google.android.material.tabs.TabLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/surface_app"
        android:alpha="0.3"
        app:layout_constraintTop_toBottomOf="@id/tabLayoutLists" />

    <FrameLayout
        android:id="@+id/containerMisColecciones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerUserLists"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="12dp"
            android:paddingBottom="140dp"
            android:clipToPadding="false"/>

        <LinearLayout
            android:id="@+id/layoutEmptyCollections"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:src="@drawable/vexo_logo"
                android:alpha="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No tienes listas aún"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/containerOtrasListas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerVexoLists"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="12dp"
            android:paddingBottom="140dp"
            android:clipToPadding="false"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
