<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <ImageButton
        android:id="@+id/btnBackAbout"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back_custom"
        app:tint="@color/primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="10dp"
        android:translationZ="10dp"/>

    <ImageView
        android:id="@+id/imgLogoAbout"
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:layout_marginTop="-20dp"
        android:src="@drawable/vexo_logo"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-60dp"
        app:cardBackgroundColor="#E6FFFFFF"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#1A7C3AED"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgLogoAbout">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textAboutTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quiénes Somos"
                    android:textColor="@color/primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="50dp"
                    android:layout_height="5dp"
                    android:layout_marginTop="8dp"
                    android:background="@color/primary" />

                <TextView
                    android:id="@+id/textAboutContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:lineSpacingExtra="8dp"
                    android:text="Vexo es una plataforma cinematográfica de última generación diseñada para los amantes del séptimo arte.\n\nNuestra misión es simplificar la forma en que descubres, organizas y disfrutas de tus películas favoritas. Utilizando las APIs más potentes del mercado, te ofrecemos datos precisos sobre premios, repartos y dónde ver cada título.\n\nEste proyecto ha sido desarrollado con pasión como Trabajo de Fin de Ciclo (TFC), buscando la excelencia visual y la mejor experiencia de usuario posible."
                    android:textColor="@color/text_primary"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Versión 1.0.5 - Premium Experience"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
