<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nestedScrollViewDetail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imgPosterDetail"
            android:layout_width="match_parent"
            android:layout_height="500dp"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="500dp"
            android:background="@drawable/gradient_overlay"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnBackDetail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back_custom"
            app:tint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layoutStatusIcons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnMenuDetail"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_more"
                app:tint="@color/white" />

            <ImageView
                android:id="@+id/statusHeart"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginTop="8dp"
                android:src="@android:drawable/btn_star_big_on"
                android:visibility="gone"
                app:tint="@color/primary"
                tools:visibility="visible" />

            <ImageView
                android:id="@+id/statusWatched"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginTop="8dp"
                android:src="@android:drawable/ic_menu_view"
                android:visibility="gone"
                app:tint="@color/accent"
                tools:visibility="visible" />

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDetailInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-100dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/background_app"
            app:layout_constraintTop_toBottomOf="@id/imgPosterDetail">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/textTagline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/textTitleDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    tools:text="Dune: Part Two" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textRatingDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="★ 8.5" />

                    <View android:layout_width="4dp" android:layout_height="4dp" android:layout_marginHorizontal="12dp" android:background="@color/text_secondary" />

                    <TextView
                        android:id="@+id/textYearDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        tools:text="2024" />

                    <View android:layout_width="4dp" android:layout_height="4dp" android:layout_marginHorizontal="12dp" android:background="@color/text_secondary" />

                    <TextView
                        android:id="@+id/textRuntimeDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        tools:text="166 min" />
                </LinearLayout>

                <TextView
                    android:id="@+id/labelSynopsis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Sinopsis"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textOverviewDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="6dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

                <!-- Menú Horizontal Premium -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/tabCast"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingEnd="24dp"
                            android:text="REPARTO"
                            android:textColor="@color/primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tabCrew"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingEnd="24dp"
                            android:text="EQUIPO"
                            android:textColor="@color/text_secondary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tabGenres"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingEnd="24dp"
                            android:text="GÉNEROS"
                            android:textColor="@color/text_secondary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tabDetails"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DETALLES"
                            android:textColor="@color/text_secondary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </HorizontalScrollView>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#15000000" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:minHeight="100dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerCastTab"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="visible"
                        android:clipToPadding="false" />

                    <LinearLayout
                        android:id="@+id/containerCrewTab"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupGenresTab"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/containerDetailsTab"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#08000000">

                            <GridLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:columnCount="2"
                                android:padding="20dp"
                                android:alignmentMode="alignMargins">

                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginBottom="16dp">
                                    <TextView android:id="@+id/labelOriginalTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TÍTULO ORIGINAL" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primary" android:letterSpacing="0.1"/>
                                    <TextView android:id="@+id/textOriginalTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" tools:text="Dune: Part Two"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginBottom="16dp">
                                    <TextView android:id="@+id/labelStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ESTADO" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primary" android:letterSpacing="0.1"/>
                                    <TextView android:id="@+id/textStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" tools:text="Released"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginBottom="16dp">
                                    <TextView android:id="@+id/labelReleaseDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ESTRENO" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primary" android:letterSpacing="0.1"/>
                                    <TextView android:id="@+id/textReleaseDateFull" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" tools:text="2024-02-27"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginBottom="16dp">
                                    <TextView android:id="@+id/labelLanguage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IDIOMA" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primary" android:letterSpacing="0.1"/>
                                    <TextView android:id="@+id/textOriginalLanguage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" tools:text="EN"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical">
                                    <TextView android:id="@+id/labelBudget" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PRESUPUESTO" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primary" android:letterSpacing="0.1"/>
                                    <TextView android:id="@+id/textBudget" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" tools:text="$190,000,000"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical">
                                    <TextView android:id="@+id/labelRevenue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RECAUDACIÓN" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primary" android:letterSpacing="0.1"/>
                                    <TextView android:id="@+id/textRevenue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" tools:text="$711,844,358"/>
                                </LinearLayout>

                            </GridLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView android:id="@+id/labelCountries" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="PAÍSES DE PRODUCCIÓN" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" android:letterSpacing="0.05" />
                        <TextView android:id="@+id/textProductionCountries" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/text_secondary" android:textSize="15sp" tools:text="United States of America" />

                        <TextView android:id="@+id/labelCompanies" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="ESTUDIOS" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" android:letterSpacing="0.05" />
                        <TextView android:id="@+id/textProductionCompanies" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/text_secondary" android:textSize="15sp" tools:text="Legendary Pictures, Warner Bros. Pictures" />

                    </LinearLayout>
                </FrameLayout>

                <!-- SECCIÓN SAGA "GLASS MORPHISM" REDISEÑADA -->
                <LinearLayout
                    android:id="@+id/cardSaga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="vertical"
                    android:background="@drawable/rounded_corners"
                    android:backgroundTint="#08000000"
                    android:padding="2dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/textSagaTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UNIVERSO Y SAGA"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.2"
                            android:textAllCaps="true" />
                        
                        <View 
                            android:layout_width="40dp" 
                            android:layout_height="3dp" 
                            android:background="@color/primary" 
                            android:layout_marginTop="4dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerSagaMovies"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:clipToPadding="false" />
                    </LinearLayout>
                </LinearLayout>

                <!-- RECOMENDACIONES -->
                <TextView
                    android:id="@+id/textSimilarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:text="RECOMENDADO PARA TI"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerSimilarMovies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddList"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="48dp"
                    android:layout_marginBottom="24dp"
                    android:text="AÑADIR A MI LISTA"
                    android:textAllCaps="true"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:backgroundTint="@color/primary"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconGravity="textStart" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
