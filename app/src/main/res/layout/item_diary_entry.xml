<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/itemDiaryRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:clipToPadding="false"
    android:paddingHorizontal="16dp"
    android:paddingBottom="12dp">

    <!-- LÍNEA TIMELINE -->
    <LinearLayout
        android:id="@+id/layoutTimeline"
        android:layout_width="20dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <View
            android:layout_width="1.5dp"
            android:layout_height="match_parent"
            android:alpha="0.1"
            android:background="@color/text_primary" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="-110dp"
            android:background="@drawable/circle_primary" />
    </LinearLayout>

    <!-- TARJETA -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDiaryContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/surface_app"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp">

            <!-- POSTER -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgDiaryPoster"
                android:layout_width="85dp"
                android:layout_height="125dp"
                android:scaleType="centerCrop"
                android:background="#F0F0F0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:shapeAppearanceOverlay="@style/RoundedImageView12dp"
                tools:src="@tools:sample/backgrounds/scenic" />

            <!-- CONTENIDO DE TEXTO -->
            <TextView
                android:id="@+id/textDiaryMovieTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="8dp"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/imgDiaryPoster"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Oppenheimer" />

            <TextView
                android:id="@+id/textDiaryDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:alpha="0.6"
                app:layout_constraintStart_toStartOf="@id/textDiaryMovieTitle"
                app:layout_constraintTop_toBottomOf="@id/textDiaryMovieTitle"
                tools:text="15 de Marzo, 2024" />

            <!-- ESTRELLAS DE VALORACIÓN -->
            <LinearLayout
                android:id="@+id/containerDiaryStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toStartOf="@id/textDiaryMovieTitle"
                app:layout_constraintTop_toBottomOf="@id/textDiaryDate" />

            <!-- LA RESEÑA DEL USUARIO -->
            <TextView
                android:id="@+id/textDiaryReview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:fontStyle="italic"
                android:maxLines="6"
                android:ellipsize="end"
                android:visibility="gone"
                app:layout_constraintStart_toEndOf="@id/imgDiaryPoster"
                app:layout_constraintTop_toBottomOf="@id/containerDiaryStars"
                app:layout_constraintEnd_toEndOf="parent"
                tools:visibility="visible"
                tools:text="Esta película es una obra maestra del cine contemporáneo, la dirección es impecable y las actuaciones son de otro nivel..." />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>