<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="115dp"
    android:layout_height="200dp"
    android:layout_marginEnd="10dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/surface_app"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- POSTER: Ahora más grande y con mejores bordes -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgPoster"
            android:layout_width="match_parent"
            android:layout_height="165dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedTopCorners16dp"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@tools:sample/backgrounds/scenic" />

        <View
            android:id="@+id/viewWatchedOverlay"
            android:layout_width="match_parent"
            android:layout_height="165dp"
            android:background="#99000000"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imgWatchedBadge"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_view"
            android:visibility="gone"
            app:tint="@color/accent"
            app:layout_constraintBottom_toBottomOf="@id/imgPoster"
            app:layout_constraintEnd_toEndOf="@id/imgPoster"
            app:layout_constraintStart_toStartOf="@id/imgPoster"
            app:layout_constraintTop_toTopOf="@id/imgPoster" />

        <!-- AREA DE TEXTO: Ajustada para el nuevo tamaño -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:paddingHorizontal="6dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/imgPoster"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/textTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                tools:text="Dune: Part Two" />

            <TextView
                android:id="@+id/textRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent"
                android:textSize="9sp"
                android:textStyle="bold"
                tools:text="★ 8.5" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>