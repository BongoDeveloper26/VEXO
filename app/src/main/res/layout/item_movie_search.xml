<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:paddingHorizontal="20dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgPosterSearch"
            android:layout_width="48dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedImageView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/textTitleSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/imgPosterSearch"
            app:layout_constraintTop_toTopOf="@id/imgPosterSearch"
            app:layout_constraintBottom_toTopOf="@id/textSubtitleSearch"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/textSubtitleSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/textTitleSearch"
            app:layout_constraintTop_toBottomOf="@id/textTitleSearch"
            app:layout_constraintBottom_toBottomOf="@id/imgPosterSearch" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Línea divisoria muy sutil (solo entre elementos) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="84dp"
        android:layout_marginEnd="20dp"
        android:background="@color/text_secondary"
        android:alpha="0.1" />

</LinearLayout>
