<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="40dp"
    app:cardElevation="24dp"
    app:cardBackgroundColor="#FDFBFF"
    app:strokeWidth="1.5dp"
    app:strokeColor="#207C3AED">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="28dp"
        android:paddingVertical="10dp">

        <!-- Círculo de Éxito con Aura -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDopamineIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#157C3AED">
            
            <ImageView
                android:id="@+id/imgDopamineIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_watched_modern"
                app:tint="@color/primary" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/textSuccessTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡ESPECTACULAR!"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/textSuccessMsg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acción guardada correctamente"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.02" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
