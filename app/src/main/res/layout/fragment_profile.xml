<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- CABECERA DE PERFIL -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:background="@drawable/bg_profile_header" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="100dp"
                android:paddingBottom="40dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProfileImage"
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    app:cardCornerRadius="65dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@color/surface_app"
                    app:strokeWidth="4dp"
                    app:strokeColor="#40FFFFFF"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_nav_profile"
                        android:padding="24dp"
                        app:tint="@color/primary" />
                </com.google.android.material.card.MaterialCardView>

                <!-- MARCO ELEGANTE PARA EL NOMBRE -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_profile_name_tag"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="10dp">

                    <TextView
                        android:id="@+id/textUserNameProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Usuario VEXO"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.01" />

                    <ImageButton
                        android:id="@+id/btnEditName"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginStart="14dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_edit"
                        android:scaleType="fitCenter"
                        app:tint="@color/white"
                        android:alpha="0.9" />
                </LinearLayout>

                <!-- CORREO ELECTRÓNICO -->
                <TextView
                    android:id="@+id/textUserEmailProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/default_email"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:alpha="0.7"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>
        </FrameLayout>

        <!-- CONTENIDO PRINCIPAL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="160dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_profile_content_gradient">

            <!-- SECCIÓN VITRINA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="48dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VITRINA DESTACADA"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="4dp"
                    android:alpha="0.7"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/slot1"
                        android:layout_width="0dp"
                        android:layout_height="175dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="1dp"
                        app:strokeColor="#10000000">
                        <ImageView
                            android:id="@+id/imgSlot1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/slot2"
                        android:layout_width="0dp"
                        android:layout_height="175dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="1dp"
                        app:strokeColor="#10000000">
                        <ImageView
                            android:id="@+id/imgSlot2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/slot3"
                        android:layout_width="0dp"
                        android:layout_height="175dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="1dp"
                        app:strokeColor="#10000000">
                        <ImageView
                            android:id="@+id/imgSlot3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/slot4"
                        android:layout_width="0dp"
                        android:layout_height="175dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="1dp"
                        app:strokeColor="#10000000">
                        <ImageView
                            android:id="@+id/imgSlot4"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </LinearLayout>

            <!-- SEPARACIÓN -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#12000000"
                android:layout_marginTop="32dp" />

            <!-- ACTIVIDAD RECIENTE -->
            <LinearLayout
                android:id="@+id/layoutActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:paddingHorizontal="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVIDAD RECIENTE"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/btnViewAllRated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Ver todas"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:padding="4dp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRecentActivity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <!-- ESTADÍSTICAS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="#08000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingVertical="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/textMoviesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/primary"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PELÍCULAS"
                            android:textColor="@color/text_secondary"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="35dp"
                        android:background="#08000000" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/textAverageRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="@color/primary"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOTA MEDIA"
                            android:textColor="@color/text_secondary"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#12000000"
                android:layout_marginTop="32dp" />

            <!-- DIARIO -->
            <LinearLayout
                android:id="@+id/layoutDiary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:visibility="gone"
                tools:visibility="visible">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:paddingHorizontal="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MI DIARIO"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/btnViewAllDiary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Ver todas"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:padding="4dp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerDiary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="48dp"
                android:text="Cerrar Sesión"
                android:textColor="#FF5252"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="#FF5252"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                android:gravity="center" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
