<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/background_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/menuMovieName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:textAlignment="center"
            tools:text="Nombre de la Película" />

        <TextView
            android:id="@+id/menuRatingDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:alpha="0.7"
            tools:text="15 de Mayo, 2024" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">
                <ImageView android:id="@+id/menuStar1" android:layout_width="42dp" android:layout_height="42dp" android:src="@drawable/ic_star_border" android:layout_marginEnd="6dp" />
                <ImageView android:id="@+id/menuStar2" android:layout_width="42dp" android:layout_height="42dp" android:src="@drawable/ic_star_border" android:layout_marginEnd="6dp" />
                <ImageView android:id="@+id/menuStar3" android:layout_width="42dp" android:layout_height="42dp" android:src="@drawable/ic_star_border" android:layout_marginEnd="6dp" />
                <ImageView android:id="@+id/menuStar4" android:layout_width="42dp" android:layout_height="42dp" android:src="@drawable/ic_star_border" android:layout_marginEnd="6dp" />
                <ImageView android:id="@+id/menuStar5" android:layout_width="42dp" android:layout_height="42dp" android:src="@drawable/ic_star_border" />
            </LinearLayout>

            <View android:layout_width="2dp" android:layout_height="30dp" android:background="#15FFFFFF" android:layout_marginHorizontal="20dp" />

            <ImageView
                android:id="@+id/imgMenuHeartQuick"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_heart_outline"
                app:tint="@color/text_secondary" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:background="@drawable/divider_elegant_gradient"
            android:layout_marginBottom="12dp"
            android:layout_marginHorizontal="-24dp" />

        <!-- OPCIÓN: ESCRIBIR RESEÑA -->
        <LinearLayout
            android:id="@+id/optionWriteReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingVertical="14dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/primary" />
            <TextView
                android:id="@+id/textOptionWriteReview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="@string/write_review"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/optionAddList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingVertical="14dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="@string/nav_list"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/optionVitrina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingVertical="14dp">
            <ImageView
                android:id="@+id/imgMenuVitrina"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_vitrina"
                app:tint="@color/primary" />
            <TextView
                android:id="@+id/textMenuVitrina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="@string/add_to_vitrina"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/optionMarkWatched"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingVertical="14dp">
            <ImageView
                android:id="@+id/imgMenuWatched"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_view"
                app:tint="@color/primary" />
            <TextView
                android:id="@+id/textMenuWatched"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="@string/mark_as_watched"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/optionViewPoster"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingVertical="14dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_report_image"
                app:tint="@color/primary" />
            <TextView
                android:id="@+id/textOptionViewPoster"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="@string/view_poster"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>