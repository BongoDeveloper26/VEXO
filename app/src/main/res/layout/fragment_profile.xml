<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:text="Mi Cuenta"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_app"
            app:strokeWidth="2dp"
            app:strokeColor="@color/primary">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_nav_profile"
                android:padding="20dp"
                app:tint="@color/text_secondary" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Usuario VEXO"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- SECCIÓN MI VITRINA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="40dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:background="@color/primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="MI VITRINA"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4">
                <com.google.android.material.card.MaterialCardView android:id="@+id/slot1" android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="4dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#157C3AED" app:strokeWidth="1dp" app:strokeColor="#337C3AED"><ImageView android:id="@+id/imgSlot1" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@android:drawable/ic_input_add" android:padding="35dp" app:tint="@color/primary" /></com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView android:id="@+id/slot2" android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="4dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#157C3AED" app:strokeWidth="1dp" app:strokeColor="#337C3AED"><ImageView android:id="@+id/imgSlot2" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@android:drawable/ic_input_add" android:padding="35dp" app:tint="@color/primary" /></com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView android:id="@+id/slot3" android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="4dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#157C3AED" app:strokeWidth="1dp" app:strokeColor="#337C3AED"><ImageView android:id="@+id/imgSlot3" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@android:drawable/ic_input_add" android:padding="35dp" app:tint="@color/primary" /></com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView android:id="@+id/slot4" android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="4dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#157C3AED" app:strokeWidth="1dp" app:strokeColor="#337C3AED"><ImageView android:id="@+id/imgSlot4" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@android:drawable/ic_input_add" android:padding="35dp" app:tint="@color/primary" /></com.google.android.material.card.MaterialCardView>
            </GridLayout>
        </LinearLayout>

        <!-- SECCIÓN ACTIVIDAD RECIENTE -->
        <LinearLayout
            android:id="@+id/layoutActivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="40dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="@color/primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="VALORACIONES RECIENTES"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                </LinearLayout>
                
                <TextView
                    android:id="@+id/btnViewAllRated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Ver todas"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="4dp" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecentActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never" />
        </LinearLayout>

        <!-- BLOQUE ESTADÍSTICAS (Movido debajo de actividad reciente) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:paddingVertical="20dp"
            android:background="@drawable/rounded_background_subtle"
            android:backgroundTint="#057C3AED">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/textMoviesCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PELÍCULAS"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="35dp"
                android:background="@color/text_secondary"
                android:alpha="0.2" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/textAverageRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:textColor="@color/primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOTA MEDIA"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1" />
            </LinearLayout>
        </LinearLayout>

        <!-- Botón Cerrar Sesión -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="Cerrar Sesión"
            android:textColor="#FF5252"
            android:textSize="15sp"
            app:icon="@android:drawable/ic_lock_power_off"
            app:iconTint="#FF5252"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp" />

    </LinearLayout>
</ScrollView>
