<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/background_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_horizontal">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:background="#20000000" />

        <TextView
            android:id="@+id/textRatingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Qué te ha parecido?"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textMovieNameRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre de la película"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/textRatingDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:alpha="0.8"
            android:layout_marginBottom="24dp"
            tools:text="lunes, 15 de Mayo de 2024" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingVertical="12dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/star1"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="4dp"
                    android:src="@drawable/ic_star_border"
                    app:tint="@color/text_secondary" />

                <ImageView
                    android:id="@+id/star2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="4dp"
                    android:src="@drawable/ic_star_border"
                    app:tint="@color/text_secondary" />

                <ImageView
                    android:id="@+id/star3"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="4dp"
                    android:src="@drawable/ic_star_border"
                    app:tint="@color/text_secondary" />

                <ImageView
                    android:id="@+id/star4"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="4dp"
                    android:src="@drawable/ic_star_border"
                    app:tint="@color/text_secondary" />

                <ImageView
                    android:id="@+id/star5"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="4dp"
                    android:src="@drawable/ic_star_border"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#15000000"
                android:layout_marginHorizontal="12dp" />

            <ImageView
                android:id="@+id/imgHeartRating"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="8dp"
                android:src="@drawable/ic_heart_outline"
                app:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="Escribe tu reseña (opcional)"
            app:boxBackgroundColor="@color/surface_app"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="1dp"
            app:counterEnabled="true"
            app:counterMaxLength="300"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editReview"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="top"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"
                android:inputType="textMultiLine|textCapSentences"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:scrollbars="vertical"
                android:maxLines="6"
                android:maxLength="300" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveRating"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="GUARDAR VALORACIÓN"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoveRating"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Quitar valoración"
            android:textColor="#FF5252" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>