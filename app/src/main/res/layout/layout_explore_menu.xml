<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#FDFBFF"
    app:cardCornerRadius="40dp"
    app:cardElevation="12dp"
    android:layout_margin="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <View
            android:layout_width="60dp"
            android:layout_height="6dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:background="#E0E0E0" />

        <TextView
            android:id="@+id/textMenuTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AJUSTES VEXO"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"
            android:letterSpacing="0.1"/>

        <!-- Opción Detalles del Perfil (NUEVO) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/optionUserDetails"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#FFB300"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_settings_circle"
                    android:backgroundTint="#1AFFB300"
                    android:padding="14dp"
                    android:src="@drawable/ic_nav_profile_modern"
                    app:tint="#FFB300" />

                <TextView
                    android:id="@+id/textOptionUserDetails"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="20dp"
                    android:text="Detalles del Perfil"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="#FFB300" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Opción Idioma -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/optionLanguage"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#7C3AED"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_settings_circle"
                    android:backgroundTint="#1A7C3AED"
                    android:padding="14dp"
                    android:src="@drawable/ic_menu_language"
                    app:tint="@color/primary" />

                <TextView
                    android:id="@+id/textOptionLanguage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="20dp"
                    android:text="Cambiar Idioma"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Opción Quiénes Somos -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/optionAbout"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#00B8D4"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_settings_circle"
                    android:backgroundTint="#1A00B8D4"
                    android:padding="14dp"
                    android:src="@drawable/ic_menu_info"
                    app:tint="#00B8D4" />

                <TextView
                    android:id="@+id/textOptionAbout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="20dp"
                    android:text="Quiénes Somos"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="#00B8D4" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="Vexo v1.0.5 — Desarrollado para TFC"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="italic" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
