<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_modern"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="#E2E8F0"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FILTROS"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:layout_marginBottom="24dp" />

        <!-- TIPO DE CONTENIDO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de contenido"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleContentType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btnTypeMovie"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTypeMovie"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PELÍCULAS"
                app:backgroundTint="@color/toggle_bg_selector"
                android:textColor="@color/toggle_text_selector"
                app:strokeColor="@color/primary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTypeTV"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SERIES"
                app:backgroundTint="@color/toggle_bg_selector"
                android:textColor="@color/toggle_text_selector"
                app:strokeColor="@color/primary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- PAÍS DE ORIGEN -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="País de origen"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupCountries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp"
            android:layout_marginBottom="24dp" />

        <!-- PLATAFORMAS (WATCH PROVIDERS) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plataformas de Streaming"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupProviders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp"
            android:layout_marginBottom="24dp" />

        <!-- GÉNEROS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Géneros"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupGenres"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp"
            android:layout_marginBottom="24dp" />

        <!-- TEMÁTICAS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Temáticas"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupKeywords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp"
            android:layout_marginBottom="24dp" />

        <!-- AÑO DE LANZAMIENTO (RANGO) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rango de años"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/textYearValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2000 - 2025"
                android:textColor="@color/primary"
                android:fontFamily="sans-serif-black" />
        </LinearLayout>

        <com.google.android.material.slider.RangeSlider
            android:id="@+id/sliderYear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="1900"
            android:valueTo="2025"
            android:stepSize="1"
            app:values="@array/initial_year_range"
            android:layout_marginBottom="24dp"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary" />

        <!-- CONTENEDOR DINÁMICO DE DURACIÓN (SOLO PELÍCULAS) -->
        <LinearLayout
            android:id="@+id/layoutDurationFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- DURACIÓN (RANGO) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Duración (minutos)"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:id="@+id/textDurationValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 - 240+"
                    android:textColor="@color/primary"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/sliderDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="240"
                android:stepSize="10"
                app:values="@array/initial_duration_range"
                android:layout_marginBottom="24dp"
                app:thumbColor="@color/primary"
                app:trackColorActive="@color/primary" />
        </LinearLayout>

        <!-- PUNTUACIÓN MÍNIMA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Puntuación mínima"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/textRatingValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0"
                android:textColor="@color/primary"
                android:fontFamily="sans-serif-black" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderRating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="10"
            android:stepSize="0.5"
            android:layout_marginBottom="32dp"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary" />

        <!-- BOTÓN APLICAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyFilters"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="APLICAR FILTROS"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="16dp"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>