<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre de la lista"
        android:textSize="13sp"
        android:textColor="@color/primary"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="8dp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"/>

    <EditText
        android:id="@+id/editListName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: Mis favoritas"
        android:inputType="textCapSentences"
        android:maxLength="20"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:background="@drawable/bg_modern_input"
        android:textColor="@color/text_primary"
        android:textSize="16sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Descripción (opcional)"
        android:textSize="13sp"
        android:textColor="@color/primary"
        android:fontFamily="sans-serif-black"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"/>

    <EditText
        android:id="@+id/editListDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Cuéntanos de qué va esta lista..."
        android:inputType="textMultiLine"
        android:minLines="3"
        android:gravity="top"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:background="@drawable/bg_modern_input"
        android:textColor="@color/text_primary"
        android:textSize="15sp"/>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchPublic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Lista Privada"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        app:thumbTint="@color/primary"
        app:trackTint="@color/primary_variant" />

    <TextView
        android:id="@+id/textPublicHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Solo tú puedes ver esta lista."
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

</LinearLayout>